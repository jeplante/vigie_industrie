{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jeplante.github.io/vigie_industrie/schemas/vigie.schema.json",
  "title": "VigieDataset",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "companies", "periods", "observations", "news"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2.0.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "companies": { "type": "array", "minItems": 4, "items": { "$ref": "#/$defs/company" } },
    "periods": { "type": "array", "minItems": 4 },
    "observations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/observation" } },
    "news": { "type": "array" }
  },
  "additionalProperties": false,
  "$defs": {
    "company": {
      "type": "object",
      "required": ["id", "name", "fullName", "ticker", "investorRelationsUrl"],
      "properties": {
        "id": { "type": "string" }, "name": { "type": "string" },
        "fullName": { "type": "string" }, "ticker": { "type": "string" },
        "investorRelationsUrl": { "type": "string", "format": "uri" }
      }
    },
    "observation": {
      "type": "object",
      "required": ["id", "companyId", "period", "metricId", "label", "value", "unit", "displayValue", "comparison", "direction", "source", "quality"],
      "properties": {
        "id": { "type": "string" }, "companyId": { "type": "string" },
        "period": { "type": "object" }, "metricId": { "type": "string" },
        "label": { "type": "string" }, "value": { "type": "number" },
        "unit": { "enum": ["CAD_PER_SHARE", "CAD_BILLION", "CAD_MILLION", "PERCENT", "NUMBER"] },
        "displayValue": { "type": "string" }, "comparison": { "type": "object" },
        "direction": { "enum": ["up", "down", "neutral"] },
        "source": { "type": "object" }, "quality": { "type": "object" }
      }
    }
  }
}
